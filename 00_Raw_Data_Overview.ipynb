    "import pandas as pd\n",
    "from ydata_profiling import ProfileReport\n",
    "\n",
    "df = pd.read_csv('VIW_FNT.csv')\n",
    "\n",
    "profile = ProfileReport(df, title=\"FluNet Raw Data Report\", explorative=True)\n",
    "profile.to_file(\"overview_flunet.html\")"
   ]
